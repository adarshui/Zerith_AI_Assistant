# ──────────────────────────────────────────────
# Zerith AI — Environment Variables
# Copy this file to .env and fill in your values
# ──────────────────────────────────────────────

# AI Provider: "groq" (cloud, free), "ollama" (local), or "openai"
LLM_PROVIDER=groq

# Groq (free cloud LLM — get key at https://console.groq.com)
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant
GROQ_BASE_URL=https://api.groq.com/openai/v1

# Ollama (local, free — needs enough RAM)
OLLAMA_MODEL=llama3
OLLAMA_BASE_URL=http://localhost:11434

# OpenAI (optional fallback)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# Vision / OCR
TESSERACT_CMD=C:\Program Files\Tesseract-OCR\tesseract.exe

# Voice
WHISPER_MODEL=base
TTS_RATE=175

# Feature Flags
ENABLE_VOICE=false
ENABLE_WEB=true
ENABLE_VISION=true
